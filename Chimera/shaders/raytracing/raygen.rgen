#version 460
#extension GL_GOOGLE_include_directive : require
#include "../common/common.glsl"

layout(set = 2, binding = 0, rgba16f) uniform image2D rtShadowAO;
layout(set = 2, binding = 1) uniform sampler2D gNormal;
layout(set = 2, binding = 2) uniform sampler2D gDepth;

layout(location = 0) rayPayloadEXT int isShadowed;

void main() 
{
    const vec2 inUV = (vec2(gl_LaunchIDEXT.xy) + vec2(0.5)) / vec2(gl_LaunchSizeEXT.xy);
    
    float depth = texture(gDepth, inUV).r;
    if (depth == 0.0) 
    {
        imageStore(rtShadowAO, ivec2(gl_LaunchIDEXT.xy), vec4(1.0, 1.0, 0.0, 1.0));
        return;
    }

    vec3 worldPos = GetWorldPos(depth, inUV, global.ubo.camera.viewProjInverse);
    vec3 normal = normalize(texture(gNormal, inUV).xyz * 2.0 - 1.0);

    // 1. 初始化随机种子 (Using common.glsl)
    uint seed = InitRandomSeed(gl_LaunchIDEXT.y * gl_LaunchSizeEXT.x + gl_LaunchIDEXT.x, global.ubo.frameCount);
    vec2 randSample = vec2(RandomFloat(seed), RandomFloat(seed));

    // 2. 计算软阴影采样方向
    vec3 L = normalize(global.ubo.sunLight.direction.xyz);
    float lightRadius = global.ubo.sunLight.intensity.y; // 假设 intensity.y 存储了半径/圆锥角

    if (lightRadius > 0.0)
    {
        vec3 tangent = abs(L.z) < 0.999 ? vec3(0, 0, 1) : vec3(1, 0, 0);
        vec3 bitangent = normalize(cross(L, tangent));
        tangent = cross(bitangent, L);

        // 使用 common.glsl 中的统一锥形采样函数
        vec3 coneSample = SquareToUniformCone(randSample, cos(lightRadius));
        L = normalize(tangent * coneSample.x + bitangent * coneSample.y + L * coneSample.z);
    }

    // 3. 硬件光线追踪阴影 (Using unified OffsetRay)
    float shadow = 1.0;
    if ((global.ubo.renderFlags & RENDER_FLAG_SHADOW_BIT) != 0)
    {
        vec3 origin = OffsetRay(worldPos, normal);
        isShadowed = 1; 
        traceRayEXT(TLAS, gl_RayFlagsTerminateOnFirstHitEXT | gl_RayFlagsOpaqueEXT | gl_RayFlagsSkipClosestHitShaderEXT,
                    0xFF, 0, 0, 1, origin, 0.001, L, 10000.0, 0);
        shadow = (isShadowed == 1) ? 0.0 : 1.0;
    }

    imageStore(rtShadowAO, ivec2(gl_LaunchIDEXT.xy), vec4(shadow, 1.0, 0.0, 1.0));
}
